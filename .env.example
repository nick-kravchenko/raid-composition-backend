# Application settings
APP_PORT=8000
FRONTEND_BASE_URL=http://localhost:4200

# Database configuration
# Use DB_HOST=localhost when running the API on the host.
# Use DB_HOST=postgres when running the API through Docker Compose.
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=app_db

# Redis configuration
# Use REDIS_HOST=localhost when running the API on the host.
# Use REDIS_HOST=redis when running the API through Docker Compose.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password

# Discord configuration
# You need to create a Discord application and get these credentials from the Discord Developer Portal.
# URL: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URL=http://localhost:4200/auth/discord/callback

# Authentication security settings
# Generate separate local values with: openssl rand -hex 32
DISCORD_TOKEN_ENCRYPTION_KEY=replace_with_32_random_bytes_encoded_as_64_hex_chars
SESSION_HMAC_SECRET=replace_with_at_least_32_random_bytes

# GeoIP settings
# GeoIP is best-effort. If this file is missing, startup still succeeds and locations remain null.
GEOIP_DATABASE_PATH=/app/local/GeoLite2-City.mmdb

# Cookie settings
# Use localhost for local development. In production, set this to your parent app domain.
COOKIE_DOMAIN=localhost
# Set true in HTTPS environments. Keep false for local plain HTTP.
COOKIE_SECURE=false
# Local same-site frontend/backend ports can use Lax. Cross-site production cookies require None plus COOKIE_SECURE=true.
COOKIE_SAME_SITE=Lax
# HTTP-only session cookie name. The frontend cannot read this cookie.
SESSION_COOKIE_NAME=session
# Readable CSRF cookie name. The frontend mirrors this value into the X-CSRF-Token header.
CSRF_COOKIE_NAME=csrf
